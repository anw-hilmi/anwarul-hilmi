name: Mengerjakan-Submision-DL

conda_env: conda.yaml

entry_points:
  main:
    parameters:
      dataset_path: {type: string, default: "Dataset-Final/train/"}
      f1: {type: int, default: 64}
      u: {type: int, default: 64}
      lr: {type: float, default: 0.0001}
    command: "python modelling.py --dataset_path {dataset_path} --f1 {f1} --u {u} --lr {lr}"