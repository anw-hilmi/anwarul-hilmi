name: Mengerjakan-Submision-DL

conda_env: conda.yaml

entry_points:
  main:
    parameters:
      train_path: {type: string, default: "Dataset-Final/train/"}
      f1: {type: int, default: 64}
      u: {type: int, default: 64}
      lr: {type: float, default: 0.0001}
    command: "python modelling.py --train_path {train_path} --f1 {f1} --u {u} --lr {lr}"
